    <key name="glass-max-z" type="d">
      <default>25.0</default>
      <summary>Maximum Z depth (Thickness)</summary>
      <description>Controls the physical thickness or depth of the glass effect.</description>
    </key>

    <key name="glass-displacement-scale" type="d">
      <default>78.5</default>
      <summary>Displacement scale</summary>
      <description>Controls the strength of the light refraction distortion.</description>
    </key>

    <key name="glass-edge-smoothing" type="d">
      <default>2.0</default>
      <summary>Edge smoothing</summary>
      <description>Geometry anti-aliasing feathering width for the glass edges.</description>
    </key>

    <key name="glass-profile-shape-n" type="d">
      <default>7.0</default>
      <summary>Profile shape N</summary>
      <description>Controls the superellipse profile shape of the glass surface curvature.</description>
    </key>

    <key name="glass-ior" type="d">
      <default>2.40</default>
      <summary>Index of Refraction (IOR)</summary>
      <description>Simulates the material's optical density (glass is typically 1.5 - 2.4).</description>
    </key>

    <key name="glass-chroma-strength" type="d">
      <default>0.006</default>
      <summary>Chromatic aberration strength</summary>
      <description>Controls the RGB color separation effect caused by refraction.</description>
    </key>

    <key name="glass-specular-intensity" type="d">
      <default>0.0</default>
      <summary>Specular intensity</summary>
      <description>The brightness of specular highlights on the glass surface.</description>
    </key>
    
    <key name="glass-shininess" type="d">
      <default>42.0</default>
      <summary>Shininess</summary>
      <description>Controls the sharpness of the specular reflections.</description>
    </key>

    <key name="glass-rim-width" type="d">
      <default>5.0</default>
      <summary>Rim light width</summary>
      <description>The width of the rim lighting band near the edges.</description>
    </key>

    <key name="glass-rim-intensity" type="d">
      <default>0.6</default>
      <summary>Rim light intensity</summary>
      <description>The overall brightness of the rim lighting.</description>
    </key>

    <key name="glass-rim-directional-power" type="d">
      <default>2.7</default>
      <summary>Rim directional power</summary>
      <description>Controls how the light direction affects the rim mask.</description>
    </key>

    <key name="glass-rim-power" type="d">
      <default>6.0</default>
      <summary>Rim Fresnel power</summary>
      <description>Controls the Fresnel effect falloff for the rim light.</description>
    </key>

    <key name="glass-rim-light-color-intensity" type="d">
      <default>1.4</default>
      <summary>Rim light color intensity</summary>
      <description>Multiplier for the rim light color brightness.</description>
    </key>

    <key name="glass-sheen-intensity" type="d">
      <default>0.32</default>
      <summary>Sheen intensity</summary>
      <description>The intensity of the background sheen across the glass surface.</description>
    </key>

    <key name="glass-light-angle-deg" type="d">
      <default>50.0</default>
      <summary>Light angle (Degrees)</summary>
      <description>The directional angle of the virtual light source illuminating the glass.</description>
    </key>

    <key name="shadow-radius" type="d">
      <default>30.0</default>
      <summary>Drop shadow radius (px)</summary>
      <description>How far the drop shadow extends past the glass edge. Helps the glass stay visible on light backgrounds (e.g. white). Set to 0 to disable.</description>
    </key>

    <key name="shadow-intensity" type="d">
      <default>0.55</default>
      <summary>Drop shadow intensity</summary>
      <description>How dark the drop shadow is. 0.0 = invisible, 1.0 = maximum darkness. Helps the glass stay visible on light backgrounds (e.g. white).</description>
    </key>

    <key name="output-logs" type="b">
